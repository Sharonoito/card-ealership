// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}





datasource db {
  provider = "postgresql"
}

enum CarStatus {
  AVAILABLE
  SOLD
}

enum AdminRole {
  SUPER_ADMIN
  INVENTORY_CONTENT_ADMIN
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         AdminRole  @default(INVENTORY_CONTENT_ADMIN)
  createdAt    DateTime   @default(now())
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  inquiryType String
  message     String
  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([createdAt])
}

model Car {
  id            String    @id @default(cuid())
  make          String
  model         String
  year          Int
  mileage       Int
  price         Float
  /// Legacy single-image field (kept for backward compatibility)
  imageUrl      String
  status        CarStatus @default(AVAILABLE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  images        CarImage[]

  // New filter fields
  bodyType      String?
  transmission  String?
  fuelType      String?
  condition     String?
  exteriorColor String?
  interiorColor String?
  trim          String?
  drivetrain    String?
  engine        String?
  features      String[]
  vehicleHistory String?
  gasMileage    String?
  isNew         Boolean   @default(false)
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  position  Int
  createdAt DateTime @default(now())

  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([carId, position])
  @@index([carId])
}
