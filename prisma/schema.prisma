// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}





datasource db {
  provider = "postgresql"
}

enum CarStatus {
  AVAILABLE
  SOLD
}

enum AdminRole {
  SUPER_ADMIN
  INVENTORY_CONTENT_ADMIN
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         AdminRole  @default(INVENTORY_CONTENT_ADMIN)
  createdAt    DateTime   @default(now())
}

model Car {
  id            String    @id @default(cuid())
  make          String
  model         String
  year          Int
  mileage       Int
  price         Float
  imageUrl      String
  status        CarStatus @default(AVAILABLE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // New filter fields
  bodyType      String?
  transmission  String?
  fuelType      String?
  condition     String?
  exteriorColor String?
  interiorColor String?
  trim          String?
  drivetrain    String?
  engine        String?
  features      String[]
  vehicleHistory String?
  gasMileage    String?
  isNew         Boolean   @default(false)
}

